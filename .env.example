# API Configuration
# Copy this file to .env.local and fill in your values
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser

# Backend API URL (adjust based on your backend server)
# Local development:
# EXPENSES_API_URL=http://localhost:7272
# Docker (container to host): http://host.docker.internal:7272

# Environment selector (server-side, runtime). Values: local | homelab.
# Drives the server-side logger's default level (local -> debug, homelab -> info).
APP_ENV=local
# Optional explicit log level override (debug | info | warn | error).
# LOG_LEVEL=debug

# Optional: Analytics, monitoring, or feature flags
# NEXT_PUBLIC_ANALYTICS_ID=
# NEXT_PUBLIC_SENTRY_DSN=

# Server-side only variables (no NEXT_PUBLIC_ prefix)
# API_SECRET_KEY=
